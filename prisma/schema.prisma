// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum UserRole {
  SUPER_ADMIN
  COMPANY_ADMIN
  ADMIN
  EMPLOYEE
  CUSTOMER
}

enum QuotationStatus {
  DRAFT
  SENT
  VIEWED
  APPROVED
  REJECTED
  EXPIRED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  COMPLETED
  FAILED
  CANCELLED
  OVERDUE
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  MOBILE_MONEY
  CARD
  CHEQUE
  AIRTEL_MONEY
  MTN_MOBILE_MONEY
  ZAMTEL_KWACHA
  OTHER
}

enum PaymentProvider {
  MANUAL
  DPO
}

enum SettlementMethod {
  BANK_ACCOUNT
  AIRTEL_MONEY
  MTN_MOBILE_MONEY
  ZAMTEL_KWACHA
}

enum DpoEnvironment {
  SANDBOX
  PRODUCTION
}

enum FollowUpStatus {
  PENDING
  COMPLETED
  RESCHEDULED
  CANCELLED
}

enum NotificationType {
  QUOTATION_CREATED
  QUOTATION_APPROVED
  PAYMENT_RECORDED
  RECEIPT_GENERATED
  EMPLOYEE_ASSIGNED
  FOLLOWUP_REMINDER
  SYSTEM_ALERT
}

// Users - for authentication
model User {
  id                    String    @id @default(cuid())
  companyId             String?
  email                 String    @unique
  password              String
  firstName             String
  lastName              String
  phone                 String?
  role                  UserRole  @default(CUSTOMER)
  isActive              Boolean   @default(true)
  isEmailVerified       Boolean   @default(false)
  lastLogin             DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  company               Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  ownedCompanies        Company[] @relation("CompanyOwner")
  customer              Customer?
  employee              Employee?
  account               Account?
  sessions              Session[]
  notifications         Notification[]
  auditLogs             AuditLog[]
  quotations            Quotation[] @relation("QuotationCreatedBy")
  payments              Payment[] @relation("PaymentRecordedBy")
  receipts              Receipt[] @relation("ReceiptGeneratedBy")
  followUps             FollowUp[] @relation("FollowUpCreatedBy")
  activityLogs          ActivityLog[]
  productImportHistories ProductImportHistory[]
  passwordResetTokens   PasswordResetToken[]

  @@index([email])
  @@index([role])
  @@index([companyId])
}

model Company {
  id                    String    @id @default(cuid())
  name                  String
  slug                  String    @unique
  ownerId               String?
  email                 String?
  phone                 String?
  about                 String?   @db.Text
  logoUrl               String?
  address               String?
  city                  String?
  region                String?
  country               String?
  postalCode            String?
  taxId                 String?
  registrationNumber    String?
  website               String?
  onboardingCompleted   Boolean   @default(false)
  isActive              Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  owner                 User?     @relation("CompanyOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  users                 User[]
  customers             Customer[]
  employees             Employee[]
  products              Product[]
  categories            Category[]
  productImportHistories ProductImportHistory[]
  quotations            Quotation[]
  payments              Payment[]
  receipts              Receipt[]
  followUps             FollowUp[]
  notifications         Notification[]
  auditLogs             AuditLog[]
  activityLogs          ActivityLog[]
  settings              CompanySetting?

  @@index([ownerId])
  @@index([slug])
}

model PasswordResetToken {
  id                    String    @id @default(cuid())
  userId                String
  tokenHash             String    @unique
  expiresAt             DateTime
  usedAt                DateTime?
  createdAt             DateTime  @default(now())

  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// NextAuth Account
model Account {
  id                 String  @id @default(cuid())
  userId             String  @unique
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// NextAuth Session
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Customers
model Customer {
  id                    String    @id @default(cuid())
  userId                String    @unique
  companyId             String?
  companyName           String?
  companyRegistration   String?
  taxId                 String?
  phone                 String
  address               String?
  city                  String?
  region                String?
  country               String?
  postalCode            String?
  contactPerson         String?
  creditLimit           Decimal   @default(0) @db.Decimal(12, 2)
  creditUsed            Decimal   @default(0) @db.Decimal(12, 2)
  status                String    @default("ACTIVE") // ACTIVE, INACTIVE, SUSPENDED
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  company               Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  quotations            Quotation[]
  payments              Payment[]
  receipts              Receipt[]
  followUps             FollowUp[]
  notifications         Notification[]
  activityLogs          ActivityLog[]

  @@index([userId])
  @@index([companyId])
  @@index([companyName])
}

// Employees
model Employee {
  id                    String    @id @default(cuid())
  userId                String    @unique
  companyId             String?
  employeeId            String    @unique
  department            String?
  position              String?
  phone                 String?
  address               String?
  hireDate              DateTime?
  salary                Decimal?  @db.Decimal(12, 2)
  performanceRating     Float?
  quotaTarget           Decimal?  @db.Decimal(12, 2)
  commissionRate        Float?
  status                String    @default("ACTIVE") // ACTIVE, INACTIVE, ON_LEAVE
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  company               Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  quotations            Quotation[] @relation("AssignedEmployee")
  followUps             FollowUp[]
  activityLogs          ActivityLog[]

  @@index([userId])
  @@index([companyId])
  @@index([employeeId])
}

// Products
model Product {
  id                    String    @id @default(cuid())
  companyId             String?
  sku                   String
  name                  String
  description           String?   @db.Text
  categoryId            String
  unitPrice             Decimal   @db.Decimal(12, 2)
  currency              String    @default("USD")
  stock                 Int       @default(0)
  reorderLevel          Int?
  image                 String?
  status                String    @default("ACTIVE") // ACTIVE, INACTIVE, DISCONTINUED
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  company               Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  category              Category  @relation(fields: [categoryId], references: [id])
  quotationItems        QuotationItem[]

  @@index([categoryId])
  @@index([companyId])
  @@index([sku])
  @@index([name])
  @@unique([companyId, sku])
}

// Product Categories
model Category {
  id                    String    @id @default(cuid())
  companyId             String?
  name                  String
  description           String?
  icon                  String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  company               Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  products              Product[]

  @@index([companyId])
  @@unique([companyId, name])
}

model ProductImportHistory {
  id                  String   @id @default(cuid())
  companyId           String?
  importedById        String
  source              String   @default("csv")
  createdCount        Int      @default(0)
  errorCount          Int      @default(0)
  categoriesCreated   Json?
  errors              Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  company             Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  importedBy          User     @relation(fields: [importedById], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([importedById])
  @@index([createdAt])
}

// Quotations
model Quotation {
  id                    String    @id @default(cuid())
  companyId             String?
  quotationNumber       String    @unique
  customerId            String
  createdById           String
  assignedEmployeeId    String?
  status                QuotationStatus @default(DRAFT)
  subtotal              Decimal   @db.Decimal(12, 2)
  taxAmount             Decimal   @db.Decimal(12, 2)
  discountAmount        Decimal   @db.Decimal(12, 2)
  total                 Decimal   @db.Decimal(12, 2)
  currency              String    @default("USD")
  notes                 String?   @db.Text
  terms                 String?   @db.Text
  validUntil            DateTime?
  viewedAt              DateTime?
  approvedAt            DateTime?
  rejectedAt            DateTime?
  rejectionReason       String?
  paymentStatus         PaymentStatus @default(PENDING)
  paymentProvider       PaymentProvider?
  paymentMethod         PaymentMethod?
  dpoTransactionToken   String?
  paymentReference      String?
  paidAt                DateTime?
  receiptNumber         String?
  settlementNote        String?   @db.Text
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  company               Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  customer              Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdBy             User      @relation("QuotationCreatedBy", fields: [createdById], references: [id])
  assignedEmployee      Employee? @relation("AssignedEmployee", fields: [assignedEmployeeId], references: [id])
  items                 QuotationItem[]
  payments              Payment[]
  receipts              Receipt[]
  followUps             FollowUp[]
  notifications         Notification[]
  activityLogs          ActivityLog[]

  @@index([customerId])
  @@index([companyId])
  @@index([createdById])
  @@index([assignedEmployeeId])
  @@index([status])
  @@index([quotationNumber])
}

// Quotation Items
model QuotationItem {
  id                    String    @id @default(cuid())
  quotationId           String
  productId             String
  quantity              Int
  unitPrice             Decimal   @db.Decimal(12, 2)
  discount              Decimal   @default(0) @db.Decimal(12, 2)
  tax                   Decimal   @default(0) @db.Decimal(12, 2)
  total                 Decimal   @db.Decimal(12, 2)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  quotation             Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  product               Product   @relation(fields: [productId], references: [id])

  @@index([quotationId])
  @@index([productId])
}

// Payments
model Payment {
  id                    String    @id @default(cuid())
  companyId             String?
  paymentNumber         String    @unique
  quotationId           String
  customerId            String
  recordedById          String
  method                PaymentMethod
  amount                Decimal   @db.Decimal(12, 2)
  currency              String    @default("USD")
  status                PaymentStatus @default(PENDING)
  reference             String?
  notes                 String?   @db.Text
  provider              PaymentProvider @default(MANUAL)
  dpoTransactionToken   String?   @unique
  receiptNumber         String?
  paymentDate           DateTime
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  company               Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  quotation             Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  customer              Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  recordedBy            User      @relation("PaymentRecordedBy", fields: [recordedById], references: [id])
  receipts              Receipt[]
  notifications         Notification[]
  activityLogs          ActivityLog[]

  @@index([quotationId])
  @@index([companyId])
  @@index([customerId])
  @@index([recordedById])
  @@index([status])
}

// Receipts
model Receipt {
  id                    String    @id @default(cuid())
  companyId             String?
  receiptNumber         String    @unique
  quotationId           String
  customerId            String
  generatedById         String
  amount                Decimal   @db.Decimal(12, 2)
  currency              String    @default("USD")
  paymentMethod         PaymentMethod
  reference             String?
  notes                 String?   @db.Text
  provider              PaymentProvider @default(MANUAL)
  paymentId             String?
  signatureImageUrl     String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  company               Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  quotation             Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  customer              Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  generatedBy           User      @relation("ReceiptGeneratedBy", fields: [generatedById], references: [id])
  payment               Payment?  @relation(fields: [paymentId], references: [id])
  notifications         Notification[]
  activityLogs          ActivityLog[]

  @@index([quotationId])
  @@index([companyId])
  @@index([customerId])
  @@index([generatedById])
}

// Follow-ups/CRM
model FollowUp {
  id                    String    @id @default(cuid())
  companyId             String?
  quotationId           String
  customerId            String
  employeeId            String
  createdById           String
  status                FollowUpStatus @default(PENDING)
  type                  String    // CALL, EMAIL, MEETING, NOTE
  callNotes             String?   @db.Text
  meetingNotes          String?   @db.Text
  feedback              String?   @db.Text
  nextFollowUpDate      DateTime?
  reminderDate          DateTime?
  reminderSent          Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  company               Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  quotation             Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  customer              Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  employee              Employee  @relation(fields: [employeeId], references: [id])
  createdBy             User      @relation("FollowUpCreatedBy", fields: [createdById], references: [id])
  notifications         Notification[]
  activityLogs          ActivityLog[]

  @@index([quotationId])
  @@index([companyId])
  @@index([customerId])
  @@index([employeeId])
  @@index([status])
}

// Notifications
model Notification {
  id                    String    @id @default(cuid())
  companyId             String?
  userId                String
  type                  NotificationType
  title                 String
  message               String    @db.Text
  relatedId             String?   // quotationId, paymentId, etc.
  relatedModel          String?   // Quotation, Payment, etc.
  isRead                Boolean   @default(false)
  readAt                DateTime?
  createdAt             DateTime  @default(now())

  // Relations
  company               Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer              Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  quotation             Quotation? @relation(fields: [quotationId], references: [id], onDelete: SetNull)
  payment               Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  followUp              FollowUp? @relation(fields: [followUpId], references: [id], onDelete: SetNull)
  receipt              Receipt?  @relation(fields: [receiptId], references: [id], onDelete: SetNull)

  customerId            String?
  quotationId           String?
  paymentId             String?
  followUpId            String?
  receiptId             String?

  @@index([userId])
  @@index([companyId])
  @@index([isRead])
  @@index([createdAt])
}

// Audit Logs
model AuditLog {
  id                    String    @id @default(cuid())
  companyId             String?
  userId                String?
  action                String    // CREATE, UPDATE, DELETE, VIEW
  entity                String    // Product, Quotation, Payment, etc.
  entityId              String
  changes               String?   @db.Text // JSON of what changed
  ipAddress             String?
  userAgent             String?
  createdAt             DateTime  @default(now())

  // Relations
  company               Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  user                  User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([userId])
  @@index([entity])
  @@index([entityId])
  @@index([createdAt])
}

// Activity Logs (timeline of customer interactions)
model ActivityLog {
  id                    String    @id @default(cuid())
  companyId             String?
  customerId            String
  userId                String?
  employeeId            String?
  activityType          String    // QUOTATION_CREATED, PAYMENT_RECEIVED, FOLLOWUP_SCHEDULED, etc.
  description           String
  details               String?   @db.Text // JSON
  createdAt             DateTime  @default(now())

  // Relations
  company               Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  customer              Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  user                  User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  employee              Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  quotation             Quotation? @relation(fields: [quotationId], references: [id], onDelete: SetNull)
  payment               Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  receipt               Receipt? @relation(fields: [receiptId], references: [id], onDelete: SetNull)
  followUp              FollowUp? @relation(fields: [followUpId], references: [id], onDelete: SetNull)

  quotationId           String?
  paymentId             String?
  receiptId             String?
  followUpId            String?

  @@index([customerId])
  @@index([companyId])
  @@index([userId])
  @@index([activityType])
  @@index([createdAt])
}

// Company Settings
model CompanySetting {
  id                    String    @id @default(cuid())
  companyId             String?   @unique
  companyName           String
  companyEmail          String
  companyPhone          String
  companyAddress        String?
  companyCity           String?
  companyRegion         String?
  companyCountry        String?
  companyPostalCode     String?
  companyTaxId          String?
  companyRegistration   String?
  defaultCurrency       String    @default("USD")
  taxRate               Float     @default(0)
  quotationPrefix       String    @default("QT")
  receiptPrefix         String    @default("RC")
  paymentPrefix         String    @default("PM")
  quotationValidDays    Int       @default(30)
  bankName              String?
  bankAccount           String?
  bankCode              String?
  settlementMethod      SettlementMethod?
  accountName           String?
  accountNumber         String?
  branch                String?
  swiftCode             String?
  mobileMoneyNetwork    String?
  mobileMoneyBusinessName String?
  mobileMoneyNumber     String?
  dpoCompanyTokenEncrypted String? @db.Text
  dpoServiceTypeEncrypted String? @db.Text
  dpoMerchantId         String?
  dpoCallbackUrl        String?
  dpoReturnUrl          String?
  dpoEnvironment        DpoEnvironment @default(SANDBOX)
  paymentSetupComplete  Boolean   @default(false)
  paymentEnabled        Boolean   @default(false)
  companyWebsite        String?
  companyLogo           String?
  signatureImageUrl     String?
  documentFont          String    @default("Helvetica")
  socialMedia           String?   @db.Text // JSON
  businessHours         String?   @db.Text // JSON
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  company               Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([companyId])
}
