# Database
DATABASE_URL="postgresql://user:password@localhost:5432/quotely_crm"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"

# Cloudinary (for image uploads)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Email (optional, for notifications)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-password"
SMTP_FROM="Quotetion <no-reply@yourdomain.com>"

# App Settings
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Quotetion"
APP_BASE_URL="http://localhost:3000"

# DPO Pay
DPO_API_URL="https://secure1.sandbox.directpay.online/API/v6/"
ENCRYPTION_KEY="replace-with-a-32-byte-random-secret"
